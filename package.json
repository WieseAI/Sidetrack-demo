{
  "name": "sidetrack",
  "private": true,
  "version": "0.0.0",
  "description": "A Chrome sidepanel that combines a kanban board with per-task time tracking. Offline-first, local-only.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "icons": "node scripts/generate-icons.js"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "preact": "^10.29.3"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.1",
    "@testing-library/preact": "^3.2.4",
    "@types/chrome": "^0.2.2",
    "@types/node": "^22.0.0",
    "happy-dom": "^20.10.6",
    "typescript": "^5.6.0",
    "vite": "^7.3.0",
    "vitest": "^4.1.9"
  }
}
